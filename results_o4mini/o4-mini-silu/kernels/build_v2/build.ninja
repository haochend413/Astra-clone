ninja_required_version = 1.3
cxx = /usr/bin/g++-11
nvcc = /home/hd9/miniconda/envs/dattri/bin/nvcc

cflags = -DTORCH_EXTENSION_NAME=gen_v2_v3 -DTORCH_API_INCLUDE_EXTENSION_H -DPYBIND11_COMPILER_TYPE=\"_gcc\" -DPYBIND11_STDLIB=\"_libstdcpp\" -DPYBIND11_BUILD_ABI=\"_cxxabi1011\" -isystem /home/hd9/miniconda/envs/dattri/lib/python3.10/site-packages/torch/include -isystem /home/hd9/miniconda/envs/dattri/lib/python3.10/site-packages/torch/include/torch/csrc/api/include -isystem /home/hd9/miniconda/envs/dattri/lib/python3.10/site-packages/torch/include/TH -isystem /home/hd9/miniconda/envs/dattri/lib/python3.10/site-packages/torch/include/THC -isystem /home/hd9/miniconda/envs/dattri/include -isystem /home/hd9/miniconda/envs/dattri/include/python3.10 -D_GLIBCXX_USE_CXX11_ABI=0 -fPIC -std=c++17 -O2 -std=c++17
post_cflags = 
cuda_cflags = -ccbin /usr/bin/gcc-11 -DTORCH_EXTENSION_NAME=gen_v2_v3 -DTORCH_API_INCLUDE_EXTENSION_H -DPYBIND11_COMPILER_TYPE=\"_gcc\" -DPYBIND11_STDLIB=\"_libstdcpp\" -DPYBIND11_BUILD_ABI=\"_cxxabi1011\" -isystem /home/hd9/miniconda/envs/dattri/lib/python3.10/site-packages/torch/include -isystem /home/hd9/miniconda/envs/dattri/lib/python3.10/site-packages/torch/include/torch/csrc/api/include -isystem /home/hd9/miniconda/envs/dattri/lib/python3.10/site-packages/torch/include/TH -isystem /home/hd9/miniconda/envs/dattri/lib/python3.10/site-packages/torch/include/THC -isystem /home/hd9/miniconda/envs/dattri/include -isystem /home/hd9/miniconda/envs/dattri/include/python3.10 -D_GLIBCXX_USE_CXX11_ABI=0 -D__CUDA_NO_HALF_OPERATORS__ -D__CUDA_NO_HALF_CONVERSIONS__ -D__CUDA_NO_BFLOAT16_CONVERSIONS__ -D__CUDA_NO_HALF2_OPERATORS__ --expt-relaxed-constexpr -gencode=arch=compute_86,code=sm_86 --compiler-options '-fPIC' -O2 --use_fast_math -std=c++17
cuda_post_cflags = 
cuda_dlink_post_cflags = 
ldflags = -shared -L/home/hd9/miniconda/envs/dattri/lib/python3.10/site-packages/torch/lib -lc10 -lc10_cuda -ltorch_cpu -ltorch_cuda -ltorch -ltorch_python -L/home/hd9/miniconda/envs/dattri/lib -lcudart

rule compile
  command = $cxx -MMD -MF $out.d $cflags -c $in -o $out $post_cflags
  depfile = $out.d
  deps = gcc

rule cuda_compile
  depfile = $out.d
  deps = gcc
  command = $nvcc --generate-dependencies-with-compile --dependency-output $out.d $cuda_cflags -c $in -o $out $cuda_post_cflags



rule link
  command = $cxx $in $ldflags -o $out

build kernel_v2.cuda.o: cuda_compile /home/hd9/Astra-clone/cuda_optimization_runs/latest/kernels/kernel_v2.cu



build gen_v2_v3.so: link kernel_v2.cuda.o

default gen_v2_v3.so
